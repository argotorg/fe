use core::ptr
use std::evm::{Evm, Log}

struct Data {
    a: u256,
}

fn raw_emit(evm: mut Evm) {
    let data = ptr::alloc<Data>()
    evm.log0(data: ptr::MemBuffer::from_raw_parts(
        ptr: ptr::as_bytes(data),
        len: core::size_of<Data>(),
    ))
}

pub fn main() uses (evm: mut Evm) {
    raw_emit(mut evm)
}
