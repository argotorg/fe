---
source: crates/codegen/tests/sonatina_ir.rs
expression: output
input_file: crates/codegen/tests/fixtures/alloc.fe
---
target = "evm-ethereum-osaka"

func private %alloc_bytes(v0.i256) -> i256 {
    block0:
        jump block1;

    block1:
        v2.*i8 = evm_malloc v0;
        v3.i256 = ptr_to_int v2 i256;
        return v3;
}

func private %bump_const() -> i256 {
    block0:
        jump block1;

    block1:
        v1.i256 = call %alloc_bytes 64.i256;
        return v1;
}

func private %main_root() {
    block0:
        jump block1;

    block1:
        v0.i256 = call %bump_const;
        evm_stop;
}


object @main {
    section main {
        entry %main_root;
    }
}
