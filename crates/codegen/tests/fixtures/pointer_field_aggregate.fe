use core::ptr

struct Holder {
    ptr: *u256,
    value: u256,
}

fn bump() uses (value: mut u256) {
    value += 1
}

pub fn pointer_field_aggregate() {
    let mut holder = Holder { ptr: ptr::alloc<u256>(), value: 1 }
    let first = holder.ptr
    with (first) {
        bump()
    }

    holder.ptr = ptr::alloc<u256>()
    let second = holder.ptr
    with (second) {
        bump()
    }
}
