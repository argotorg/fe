use core::prelude::*
use std::evm::Address
use std::evm::Create

mod FactoryMsg {
    use core::prelude::*
    use super::*

    pub struct Deploy {
        pub x: u256,
        pub y: u256,
    }

    impl core::message::MsgVariant<std::abi::Sol> for Deploy {
        type Args = (u256, u256)
        type Return = Address
        const SELECTOR: u32 = 1
    }

    impl Deploy {
        pub fn decode(mut _ d: std::abi::sol::SolDecoder<std::evm::calldata::CallData>) -> Self {
            let x = u256::decode(d)
            let y = u256::decode(d)
            return Self { x: x, y: y }
        }
    
    }

    pub struct Deploy2 {
        pub x: u256,
        pub y: u256,
        pub salt: u256,
    }

    impl core::message::MsgVariant<std::abi::Sol> for Deploy2 {
        type Args = (u256, u256, u256)
        type Return = Address
        const SELECTOR: u32 = 2
    }

    impl Deploy2 {
        pub fn decode(mut _ d: std::abi::sol::SolDecoder<std::evm::calldata::CallData>) -> Self {
            let x = u256::decode(d)
            let y = u256::decode(d)
            let salt = u256::decode(d)
            return Self { x: x, y: y, salt: salt }
        }
    
    }
}

pub struct Pair {
    x: u256,
    y: u256,
}

pub contract Child {
    state: Pair,
}

pub contract Factory uses (mut create: Create) {

    recv FactoryMsg {
        Deploy { x, y } -> Address uses (mut create) {
            create.create<Child>(value: 0, args: (x, y))
        }
        Deploy2 { x, y, salt } -> Address uses (mut create) {
            create.create2<Child>(value: 0, args: (x, y), salt: salt)
        }
    }
}
