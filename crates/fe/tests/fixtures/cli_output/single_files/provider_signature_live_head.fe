// FCO Level 1 (W-D) NEGATIVE A — live abstract head, named at a typed boundary.
//
// `Evidence<P<T>>` with `P: * -> Constraint` is a LIVE variable-headed goal.
// The narrow `CapabilityGoal` carrier has no variable-head variant by
// construction, so a live head can never be carried to the solver; the goal
// position is reported with the abstract-head diagnostic (`6-0008`), the same
// boundary as a `where P<T>` predicate. Genuine variable-headed solving is
// build-trigger-gated research (FCO_ABSTRACT_HEAD_RESEARCH_DOSSIER.md).

use core::derive::Derive
use core::derive::Evidence
use core::derive::ImplBuilder
use core::derive::Reflect

trait Real {
    fn r(self) -> bool
}

impl Derive<Real> for LiveHead {
    const fn derive<P: * -> Constraint, T>(ev: own Evidence<P<T>>) -> Evidence<P<T>>
        uses (
            reflect: Reflect<T>,
            builder: mut ImplBuilder<P<T>>,
        )
    {
        builder.emit_method("r", builder.bool(true))
        builder.finish()
        ev
    }
}

struct LiveHead {}
