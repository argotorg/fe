// FCO L2 anti-leak: lock the executor's DuplicateFinish invariant
// (provider_executor.rs:177-211). A derive provider's command program may call
// `builder.finish()` AT MOST ONCE. This is the use-once discipline enforced by
// the EXECUTOR (borrowck skips provider bodies, check.rs:185-186), the L2 layer
// of the capability floor design.
//
// PASS CRITERIA: a provider-failed diagnostic whose message is
//   "the provider called `finish` more than once".

use core::derive::Derive
use core::derive::Evidence
use core::derive::ImplBuilder
use core::derive::Reflect

trait Marker {}

impl Derive<Marker> for TwiceFinish {
    const fn derive<T>(ev: own Evidence<Marker<T>>) -> Evidence<Marker<T>>
        uses (
            reflect: Reflect<T>,
            builder: mut ImplBuilder<Marker<T>>,
        )
    {
        builder.finish()
        // BUG: a second `finish` on the same builder.
        builder.finish()
        ev
    }
}

struct Point {
    x: u256,
}

derive Marker for Point using TwiceFinish

struct TwiceFinish {}
