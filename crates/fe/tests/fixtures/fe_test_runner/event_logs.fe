use std::abi::Bytes

#[event]
struct Transfer {
    #[indexed]
    from: Address,
    #[indexed]
    to: Address,
    value: u256,
}

#[event]
struct SimpleEvent {
    value: u256,
}

#[event]
struct AllIndexed {
    #[indexed]
    a: u256,
    #[indexed]
    b: u256,
    #[indexed]
    c: u256,
}

// Multi-field event with at least one dynamic data field. Regression
// anchor for a HIR event-desugar bug where the tuple of data fields was
// materialized after the encoder reserved head space — its allocation
// landed between the reserved head and the tail from `append_tail`, so
// `enc.finish()` returned a buffer that stretched past the real tail end
// and included raw tuple memory. The expected snapshot here is exactly
// the canonical ABI encoding of `(uint256, bytes)`; pre-fix this field
// was bloated with garbage words.
#[event]
struct DynamicPayload {
    header: u256,
    payload: Bytes,
}

#[test]
fn test_transfer_event() uses (evm: mut Evm) {
    let from = Address { inner: 0x1111111111111111111111111111111111111111 }
    let to = Address { inner: 0x2222222222222222222222222222222222222222 }
    evm.emit(Transfer { from, to, value: 1000 })
}

#[test]
fn test_simple_event() uses (evm: mut Evm) {
    evm.emit(SimpleEvent { value: 42 })
}

#[test]
fn test_all_indexed() uses (evm: mut Evm) {
    evm.emit(AllIndexed { a: 1, b: 2, c: 3 })
}

#[test]
fn test_dynamic_payload() uses (evm: mut Evm) {
    evm.emit(DynamicPayload { header: 0xdeadbeef, payload: Bytes::empty() })
}
