// PS2 regression + std-lib derive: a `Clone` derive provider authored on the
// existing provider/builder bridge, exercised through method calls.
//
// History: this was a quarantined repro — the provider generated `impl Clone for
// Point` fine, but `p.clone()` was ambiguous because method resolution listed the
// `impl<T: Copy> Clone for T` blanket as a candidate WITHOUT discharging
// `Point: Copy`. The fix (PS2): method-candidate assembly now uses the
// constraint-gated impl set, so a conditional blanket impl whose `where` clause
// is unsatisfiable for the concrete receiver is dropped. It now compiles + runs.

use core::clone::Clone
use core::derive::Derive
use core::derive::Evidence
use core::derive::ImplBuilder
use core::derive::Reflect

impl Derive<Clone> for StableClone {
    const fn derive<T>(ev: own Evidence<Clone<T>>) -> Evidence<Clone<T>>
        uses (
            reflect: Reflect<T>,
            builder: mut ImplBuilder<Clone<T>>,
        )
    {
        if reflect.is_struct() {
            // Self { f0: self.f0.clone(), f1: self.f1.clone(), .. }
            let mut init = builder.struct_init()
            for field in reflect.fields() {
                builder.require<Clone>(field.ty())
                init = builder.with_field(
                    init,
                    field,
                    builder.call(builder.field_get(builder.self_ref(), field), "clone"),
                )
            }
            builder.emit_method("clone", init)
        }
        if reflect.is_enum() {
            // match self {
            //     V(lhs) => Self::V(lhs.0.clone(), ..),  // payload variants
            //     U      => Self::U,                      // unit variants
            //     ..
            // }
            // Built with the lower-level builder commands rather than a quote:
            // `variant_pat` binds the matched payload under the `lhs` group,
            // `variant_binder` reaches one bound field (the same machinery the
            // StableEq enum arms use through `${variant}(lhs)` / `lhs.${field}`),
            // and `variant_init` + `with_field` reconstruct the same variant with
            // each field cloned. Unit variants take no fields, so they rebuild as
            // the bare variant.
            let mut body = builder.match_expr(builder.self_ref())
            for variant in reflect.variants() {
                let pat = builder.variant_pat(variant, "lhs")
                let mut init = builder.variant_init(variant)
                for field in variant.fields() {
                    builder.require<Clone>(field.ty())
                    init = builder.with_field(
                        init,
                        field,
                        builder.call(builder.variant_binder(variant, field, "lhs"), "clone"),
                    )
                }
                body = builder.with_arm(body, pat, init)
            }
            builder.emit_method("clone", body)
        }
        builder.finish()
        ev
    }
}

struct Point {
    x: u256,
    y: u256,
}

derive Clone for Point using StableClone

struct Nested {
    p: Point,
    flag: bool,
}

derive Clone for Nested using StableClone

#[test]
fn clone_struct_copies_fields() {
    let p = Point { x: 7, y: 9 }
    let q = p.clone()
    assert!(q.x == 7)
    assert!(q.y == 9)
}

#[test]
fn clone_nested_struct_recurses() {
    let n = Nested { p: Point { x: 1, y: 2 }, flag: true }
    let m = n.clone()
    assert!(m.p.x == 1)
    assert!(m.p.y == 2)
    assert!(m.flag)
}

// The generated impl satisfies a generic `Clone` bound like a hand-written one.
fn dup<T: Clone>(_ value: T) -> T {
    value.clone()
}

#[test]
fn generated_impl_satisfies_generic_bound() {
    let p = Point { x: 5, y: 6 }
    let q = dup(p)
    assert!(q.x == 5)
    assert!(q.y == 6)
}

// --- enum support (expression-first pressure test) -------------------------
// The SAME StableClone provider above also handles enums: it builds a
// `match self` that reconstructs each variant with every payload field cloned.
// Covers unit, tuple-payload, and record-payload variants. `Eq` is derived
// (canonical) so the clones can be compared structurally.

#[derive(Eq)]
enum Shape {
    Dot,
    Circle(u256),
    Rect { w: u256, h: u256 },
}

derive Clone for Shape using StableClone

#[test]
fn clone_enum_unit_variant() {
    assert!(Shape::Dot.clone().eq(Shape::Dot))
}

#[test]
fn clone_enum_tuple_payload() {
    assert!(Shape::Circle(42).clone().eq(Shape::Circle(42)))
    assert!(!Shape::Circle(42).clone().eq(Shape::Circle(7)))
}

#[test]
fn clone_enum_record_payload() {
    let r = Shape::Rect { w: 3, h: 5 }
    assert!(r.clone().eq(Shape::Rect { w: 3, h: 5 }))
}

#[test]
fn clone_enum_distinguishes_variants() {
    assert!(!Shape::Dot.clone().eq(Shape::Circle(0)))
}

struct StableClone {}
