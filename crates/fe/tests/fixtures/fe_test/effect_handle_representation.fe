use core::{AddressSpace, EffectHandle, EffectRef}
use std::evm::{Evm, RawMem}

struct TaggedPtr<T> {
    tag: u256,
    addr: u256,
}

impl<T> EffectHandle for TaggedPtr<T> {
    type Target = T
    const SPACE: AddressSpace = AddressSpace::Memory

    fn from_raw(_ raw: u256) -> Self {
        Self { tag: 11, addr: raw }
    }

    fn raw(self) -> u256 {
        self.addr
    }
}

struct TaggedHolder<T> {
    ptr: TaggedPtr<T>,
    marker: u256,
}

fn identity_tagged(_ ptr: TaggedPtr<u256>) -> TaggedPtr<u256> {
    ptr
}

fn tagged_raw() -> u256 uses (ptr: TaggedPtr<u256>) {
    ptr.raw()
}

fn tagged_tag() -> u256 uses (ptr: TaggedPtr<u256>) {
    ptr.tag
}

#[test]
fn ordinary_effect_handles_keep_their_full_adt_representation() {
    let ptrs: [TaggedPtr<u256>; 2] = [
        TaggedPtr { tag: 21, addr: 0x100 },
        TaggedPtr { tag: 22, addr: 0x120 },
    ]
    let holder = TaggedHolder { ptr: ptrs[1], marker: 33 }
    let ptr = identity_tagged(holder.ptr)
    assert!(ptr.tag == 22)
    assert!(ptr.raw() == 0x120)
    assert!(holder.marker == 33)
}

#[test]
fn effect_boundaries_use_raw_and_from_raw() {
    let ptr = TaggedPtr<u256> { tag: 99, addr: 0x100 }
    let raw = with (ptr) { tagged_raw() }
    assert!(raw == 0x100)

    let ptr = TaggedPtr<u256> { tag: 99, addr: 0x100 }
    let tag = with (ptr) { tagged_tag() }
    assert!(tag == 11)
}

struct OffsetPtr<T> {
    encoded: u256,
}

impl<T> EffectHandle for OffsetPtr<T> {
    type Target = T
    const SPACE: AddressSpace = AddressSpace::Memory

    fn from_raw(_ raw: u256) -> Self {
        Self { encoded: raw + 32 }
    }

    fn raw(self) -> u256 {
        self.encoded - 32
    }
}

impl<T> EffectRef<T> for OffsetPtr<T> {}

struct OffsetHolder<T> {
    marker: u256,
    ptr: OffsetPtr<T>,
}

fn read_value() -> u256 uses (value: u256) {
    value
}

#[test]
fn nonidentity_handle_encoding_addresses_the_raw_target() uses (evm: mut Evm) {
    evm.mstore(addr: 0x100, value: 11)
    evm.mstore(addr: 0x120, value: 22)
    let ptr: OffsetPtr<u256> = OffsetPtr::from_raw(0x100)
    assert!(ptr.encoded == 0x120)
    let value = with (ptr) { read_value() }
    assert!(value == 11)

    let holder: OffsetHolder<u256> =
        OffsetHolder { marker: 9, ptr: OffsetPtr::from_raw(0x120) }
    let value = with (holder.ptr) { read_value() }
    assert!(value == 22)
}

struct FixedPtr<T> {}

impl<T> EffectHandle for FixedPtr<T> {
    type Target = T
    const SPACE: AddressSpace = AddressSpace::Memory

    fn from_raw(_ raw: u256) -> Self {
        assert!(raw == 0x100)
        Self {}
    }

    fn raw(self) -> u256 {
        0x100
    }
}

impl<T> EffectRef<T> for FixedPtr<T> {}

fn fixed_raw() -> u256 uses (ptr: FixedPtr<u256>) {
    ptr.raw()
}

#[test]
fn zero_sized_handles_convert_without_a_fake_runtime_payload() uses (evm: mut Evm) {
    evm.mstore(addr: 0x100, value: 77)
    let ptr = FixedPtr<u256> {}
    let value = with (ptr) { read_value() }
    assert!(value == 77)

    let ptr = FixedPtr<u256> {}
    let raw = with (ptr) { fixed_raw() }
    assert!(raw == 0x100)
}
