// M4 acceptance: derived EIP-712 struct hashing, generated by a derive
// provider written in Fe (`StableEip712`, in `std::eip712`).
//
// Three layers of evidence:
// 1. PRIMARY ORACLE — the same struct shape derived AND hand-written (same
//    struct name via a nested module twin); equal `hash712` outputs for
//    several values. Self-contained: catches encoding drift with no
//    external constants.
// 2. KNOWN VECTORS — the canonical EIP-712 `Mail`/`Person` example and the
//    `EIP712Domain` separator from the spec's own reference implementation:
//    https://raw.githubusercontent.com/ethereum/EIPs/master/assets/eip-712/Example.sol
//    (linked from https://eips.ethereum.org/EIPS/eip-712). Expected values:
//      hashStruct(mail)  = 0xc52c0ee5d84264471806290a3f2c4cecfc5490626bf912d01f240d7a274b371e
//      domainSeparator   = 0xf2cee375fa42b42143804025fc449deafd50cc031ca257e0b194a650a912090f
//    Both reproduced independently with a from-scratch keccak-f[1600]
//    implementation at fixture-writing time (2026-06-10).
// 3. COMPOSITION — a struct containing a struct, both derived (one nesting
//    level), including the duplicate-reference dedup the Mail example needs
//    (`Person` appears as two field types but its descriptor is appended
//    once).
//
// The provider lives in `std::eip712` (next to the trait, which needs
// std's EVM keccak for string hashing), so requests select it by name with
// `using StableEip712` rather than the bare canonical form.

use std::eip712::Eip712
use std::eip712::Hash712
use std::evm::Address

// --- 1. primary oracle: derived == hand-written twin ----------------------

struct Payment {
    amount: u256,
    payee: Address,
    flag: bool,
    memo: String<12>,
}

derive Eip712 for Payment using StableEip712

mod manual {
    use std::eip712::Eip712
    use std::eip712::Hash712
    use std::evm::Address

    // Same name and shape as the top-level `Payment`, with the impl a
    // careful human would write. `append_members` even uses a different
    // piece split (three semantic chunks vs the provider's name/text
    // alternation): only the concatenated bytes matter.
    pub struct Payment {
        pub amount: u256,
        pub payee: Address,
        pub flag: bool,
        pub memo: String<12>,
    }

    impl Eip712 for Payment {
        const NAME: String<31> = "Payment"
        fn append_members(_ acc: Hash712) -> Hash712 {
            acc.piece("Payment(uint256 amount,")
                .piece("address payee,bool flag,")
                .piece("string memo)")
        }
        fn hash712(self) -> u256 {
            Hash712::new()
                .word(Self::append_members(Hash712::new()).finish())
                .word(self.amount.hash712())
                .word(self.payee.hash712())
                .word(self.flag.hash712())
                .word(self.memo.hash712())
                .finish()
        }
    }
}

#[test]
fn derived_matches_handwritten() {
    let d = Payment {
        amount: 42,
        payee: Address { inner: 0x1234 },
        flag: true,
        memo: "thanks",
    }
    let m = manual::Payment {
        amount: 42,
        payee: Address { inner: 0x1234 },
        flag: true,
        memo: "thanks",
    }
    assert!(d.hash712() == m.hash712())
}

#[test]
fn derived_matches_handwritten_more_values() {
    let d0 = Payment { amount: 0, payee: Address { inner: 0 }, flag: false, memo: "" }
    let m0 = manual::Payment { amount: 0, payee: Address { inner: 0 }, flag: false, memo: "" }
    assert!(d0.hash712() == m0.hash712())

    let d1 = Payment {
        amount: 0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff,
        payee: Address { inner: 0xCD2a3d9F938E13CD947Ec05AbC7FE734Df8DD826 },
        flag: true,
        memo: "twelve chars",
    }
    let m1 = manual::Payment {
        amount: 0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff,
        payee: Address { inner: 0xCD2a3d9F938E13CD947Ec05AbC7FE734Df8DD826 },
        flag: true,
        memo: "twelve chars",
    }
    assert!(d1.hash712() == m1.hash712())
}

#[test]
fn derived_value_sensitivity() {
    let a = Payment { amount: 1, payee: Address { inner: 2 }, flag: false, memo: "x" }
    let b = Payment { amount: 1, payee: Address { inner: 2 }, flag: false, memo: "y" }
    let c = Payment { amount: 2, payee: Address { inner: 2 }, flag: false, memo: "x" }
    assert!(a.hash712() != b.hash712())
    assert!(a.hash712() != c.hash712())
}

// --- 2 + 3. known vectors (composition included) ---------------------------
//
// The canonical example from the EIP-712 spec assets (Example.sol):
// encodeType(Mail) =
//   "Mail(Person from,Person to,string contents)Person(string name,address wallet)"
// `Person` is referenced by two fields but its descriptor appears once.

struct Person {
    name: String<8>,
    wallet: Address,
}

struct Mail {
    from: Person,
    to: Person,
    contents: String<16>,
}

derive Eip712 for Person using StableEip712
derive Eip712 for Mail using StableEip712

#[test]
fn known_vector_mail_struct_hash() {
    let mail = Mail {
        from: Person {
            name: "Cow",
            wallet: Address { inner: 0xCD2a3d9F938E13CD947Ec05AbC7FE734Df8DD826 },
        },
        to: Person {
            name: "Bob",
            wallet: Address { inner: 0xbBbBBBBbbBBBbbbBbbBbbbbBBbBbbbbBbBbbBBbB },
        },
        contents: "Hello, Bob!",
    }
    assert!(mail.hash712() == 0xc52c0ee5d84264471806290a3f2c4cecfc5490626bf912d01f240d7a274b371e)
}

// encodeType(Mail) hashed through the generated `append_members` chain (the
// same chain the derived `hash712` uses for its type hash) against the
// canonical descriptor text, byte for byte.
#[test]
fn known_vector_mail_type_hash() {
    let derived = Person::append_members(Mail::append_members(Hash712::new())).finish()
    let expected = Hash712::new()
        .piece("Mail(Person from,Person to,")
        .piece("string contents)")
        .piece("Person(string name,")
        .piece("address wallet)")
        .finish()
    assert!(derived == expected)
}

struct EIP712Domain {
    name: String<12>,
    version: String<4>,
    chainId: u256,
    verifyingContract: Address,
}

derive Eip712 for EIP712Domain using StableEip712

#[test]
fn known_vector_domain_separator() {
    let domain = EIP712Domain {
        name: "Ether Mail",
        version: "1",
        chainId: 1,
        verifyingContract: Address { inner: 0xCcCCccccCCCCcCCCCCCcCcCccCcCCCcCcccccccC },
    }
    assert!(domain.hash712() == 0xf2cee375fa42b42143804025fc449deafd50cc031ca257e0b194a650a912090f)
}

// Composition oracle: derived nested struct against a hand-written outer
// twin whose fields use the DERIVED inner type — proving the generated
// impls compose with hand-written code through the same trait surface. The
// twin appends `Pt`'s descriptor ONCE, so it also pins the derived dedup
// (`Pt` appears as two field types).

struct Pt {
    x: u256,
    y: u256,
}

struct Line {
    a: Pt,
    b: Pt,
}

derive Eip712 for Pt using StableEip712
derive Eip712 for Line using StableEip712

mod manual_line {
    use std::eip712::Eip712
    use std::eip712::Hash712

    pub struct Line {
        pub a: super::Pt,
        pub b: super::Pt,
    }

    impl Eip712 for Line {
        const NAME: String<31> = "Line"
        fn append_members(_ acc: Hash712) -> Hash712 {
            acc.piece("Line(Pt a,Pt b)")
        }
        fn hash712(self) -> u256 {
            let type_hash: u256 = super::Pt::append_members(
                Self::append_members(Hash712::new()),
            ).finish()
            Hash712::new()
                .word(type_hash)
                .word(self.a.hash712())
                .word(self.b.hash712())
                .finish()
        }
    }
}

#[test]
fn composed_derived_matches_handwritten() {
    let d = Line { a: Pt { x: 1, y: 2 }, b: Pt { x: 3, y: 4 } }
    let m = manual_line::Line { a: Pt { x: 1, y: 2 }, b: Pt { x: 3, y: 4 } }
    assert!(d.hash712() == m.hash712())
}

// encodeType(Line) = "Line(Pt a,Pt b)Pt(uint256 x,uint256 y)" through the
// generated descriptor chain.
#[test]
fn composed_type_hash_appends_inner() {
    let derived = Pt::append_members(Line::append_members(Hash712::new())).finish()
    let expected = Hash712::new()
        .piece("Line(Pt a,Pt b)")
        .piece("Pt(uint256 x,uint256 y)")
        .finish()
    assert!(derived == expected)
}

// Generated impls satisfy generic bounds like hand-written ones.
fn hash_of<T: Eip712>(_ value: T) -> u256 {
    value.hash712()
}

#[test]
fn generated_impl_satisfies_generic_bound() {
    let p = Pt { x: 7, y: 8 }
    assert!(hash_of(p) == p.hash712())
}
