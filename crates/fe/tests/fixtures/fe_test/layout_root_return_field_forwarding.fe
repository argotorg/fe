use std::evm::{Evm, StorageMap}

struct Pair<const LEFT: u256 = _, const RIGHT: u256 = _> {
    left: StorageMap<u256, u256, LEFT>,
    right: StorageMap<u256, u256, RIGHT>,
}

fn left_map<const LEFT: u256, const RIGHT: u256>(
    pair: Pair<LEFT, RIGHT>,
) -> StorageMap<u256, u256, LEFT> {
    pair.left
}

fn read_left<const LEFT: u256, const RIGHT: u256>(
    pair: Pair<LEFT, RIGHT>,
    key: u256,
) -> u256 {
    left_map(pair: pair).get(key: key)
}

msg Msg {
    #[selector = 1]
    Set { lane: usize, key: u256, value: u256 },

    #[selector = 2]
    Get { lane: usize, key: u256 } -> u256,
}

pub contract C {
    mut pairs: [Pair; 2],

    recv Msg {
        Set { lane, key, value } uses (mut pairs) {
            pairs[lane].left.set(key: key, value: value)
        }

        Get { lane, key } -> u256 uses (pairs) {
            read_left(pair: pairs[lane], key: key)
        }
    }
}

#[test]
fn returned_values_preserve_field_layout_sources() uses (evm: mut Evm) {
    let c = evm.create2<C>(value: 0, args: (), salt: 1)
    evm.call(
        addr: c,
        gas: 200000,
        value: 0,
        message: Msg::Set { lane: 1, key: 7, value: 42 },
    )
    let value: u256 = evm.call(
        addr: c,
        gas: 200000,
        value: 0,
        message: Msg::Get { lane: 1, key: 7 },
    )
    assert!(value == 42)
}
