// CASCADE demotion — a DERIVED default impl and a hand-written OVERRIDE impl of
// a NON-canonical trait coexist.
//
// THE DREAM: the "derive the default, override it in a scope" pattern. For a
//   non-canonical trait (`core::ops::Eq`), a DERIVED default impl (the
//   CoreDerives-origin `#[derive(Eq)]` provider output) and a hand-written
//   OVERRIDE `impl Eq for Speaker` compile together WITHOUT a coherence
//   conflict — the cascade (C3c-3) demotes global coherence for non-canonical
//   goals from "exactly-one" to "the default + an override may coexist".
// PASS CRITERIA: the program compiles (no `5-0001` conflicting-impl
//   diagnostic); both impls are accepted as real global impls. Which one a call
//   uses is asserted in cascade_unscoped_default.fe / cascade_scoped_override.fe;
//   here we just prove COEXISTENCE.
// DRIVEN-BY: C3c-3 (the demotion flip — the non-canonical branch of the
//   `is_single_impl` conflict gate now permits a second impl).
// SURFACE: no impl is ever NAMED. `#[derive(Eq)]` mints the default; a plain
//   `impl Eq for Speaker` is the override. The internal default/override
//   discriminator is CoreDerives-origin (`implementor_is_default_marked`).
//
// `Eq` is non-canonical (`is_single_impl` is false for `core::ops::Eq`): it is
// NOT in the { AbiSize, Encode, Decode, StorageKey } money-floor set, so a second
// impl is permitted.

use core::ops::Eq

// DERIVED DEFAULT: structural equality, generated by the CoreDerives `StableEq`
// provider. This is the default-tier (CoreDerives-origin) impl.
#[derive(Eq)]
struct Speaker {
    id: u256,
}

// HAND-WRITTEN OVERRIDE: a second real global `impl Eq for Speaker`. Today this
// was a hard `5-0001` conflict; after C3c-3 it coexists with the derived default.
// This override treats every Speaker as equal (a deliberately distinct answer
// from the structural default).
impl Eq for Speaker {
    fn eq(self, _ other: Speaker) -> bool {
        true
    }
}

// Coexistence is observable just by this file type-checking: the OVERRIDE above
// does not abort compilation. The derived default is still selected for an
// unscoped call (see cascade_unscoped_default.fe).
#[test]
fn default_and_override_coexist_and_compile() {
    let a = Speaker { id: 1 }
    let b = Speaker { id: 2 }
    // Unscoped: resolves to the derived (default-tier) structural impl. The point
    // of THIS fixture is that the OVERRIDE impl does not abort compilation; the
    // exact selection is pinned in the other cascade fixtures.
    let _ = a.eq(b)
    assert!(true)
}
