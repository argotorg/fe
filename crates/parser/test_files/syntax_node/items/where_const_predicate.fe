struct Wrap<T> where T: Sized, T::SIZE <= 32 {
    inner: T
}

enum Opt<T> where T: Sized, T::SIZE <= 32 {
    Some(T),
    None,
}

trait Big<T> where T: Sized, T::SIZE >= 50 {
    fn big(self) -> u256
}

trait Bounded {
    fn must_fit<T>() where T: Sized, T::SIZE < 100
    fn check_brace<T>() where { T::SIZE < 100 }
    fn with_default<T>() where T: Sized, T::SIZE < 100 {
        5
    }
}

