use core::prelude::*
use std::prelude::*

pub struct Foo<const N: u256> {}

impl<const N: u256> Foo<N> {
    const DOUBLE: u256 = N * 2
    pub fn get_double(self) -> u256 {
        Self::DOUBLE
    }

}
