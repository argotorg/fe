use core::prelude::*
use std::prelude::*

trait Sized {
    const SIZE: u256;
}

fn needs_big<T>() where T: Sized, T::SIZE >= 50 {}

struct BigOnly<T> where T: Sized, T::SIZE >= 50 {
    value: T,
}

enum BigEnum<T> where T: Sized, T::SIZE >= 50 {
    Value(T),
}
