use core::prelude::*
use std::prelude::*
use std::evm::Address

pub struct Transfer {
    pub from: Address,
    pub to: Address,
    pub amount: u256,
}

impl std::evm::Event for Transfer {
    const TOPIC0: u256 = core::keccak(("Transfer", "(", Address::SOL_TYPE, ",", Address::SOL_TYPE, ",", u256::SOL_TYPE, ")"))

    #[inline(always)]
    fn emit<L: std::evm::Log>(own self, _ log: mut L) {
        log.log3(data: std::evm::encode_abi_payload((self.amount)), topic0: Self::TOPIC0, topic1: self.from.as_topic(), topic2: self.to.as_topic())
    }
}
