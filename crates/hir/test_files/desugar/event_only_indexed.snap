use core::prelude::*
use std::evm::Address

struct Approval {
    owner: Address,
    spender: Address,
    value: u256,
}

impl std::evm::Event for Approval {
    const TOPIC0: u256 = core::keccak("Approval(address,address,uint256)")

    fn emit<L: std::evm::Log>(self, mut log: L) {
        log.log4(0, 0, Self::TOPIC0, std::evm::address_to_word(self.owner), std::evm::address_to_word(self.spender), self.value.downcast_unchecked())
    }
}
