use core::prelude::*
use std::prelude::*
use std::abi::sol::Uint160
use std::abi::sol::Int24

struct Swap {
    sender: Uint160,
    tick: Int24,
    amount: u256,
}

impl std::evm::Event for Swap {
    const TOPIC0: u256 = core::keccak(("Swap", "(", Uint160::SOL_TYPE, ",", Int24::SOL_TYPE, ",", u256::SOL_TYPE, ")"))

    #[inline(always)]
    fn emit<L: std::evm::Log>(own self, _ log: mut L) {
        log.log2(data: std::evm::encode_abi_payload((self.tick, self.amount)), topic0: Self::TOPIC0, topic1: self.sender.as_topic())
    }
}
