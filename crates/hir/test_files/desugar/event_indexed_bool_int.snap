use core::prelude::*
use std::prelude::*

struct Flags {
    ok: bool,
    delta: i8,
    value: u256,
}

impl std::evm::Event for Flags {
    const TOPIC0: u256 = core::keccak(("Flags", "(", bool::SOL_TYPE, ",", i8::SOL_TYPE, ",", u256::SOL_TYPE, ")"))

    #[inline(always)]
    fn emit<L: std::evm::Log>(own self, _ log: mut L) {
        log.log3(data: std::evm::encode_abi_payload((self.value)), topic0: Self::TOPIC0, topic1: self.ok.as_topic(), topic2: self.delta.as_topic())
    }
}
