trait BoundConst {
    type X
    const C: Self::X
}

struct BoundConstStruct {}

struct ConstSlot<const N: u32> {}

impl BoundConst for BoundConstStruct {
    type X = u32
    const C: Self::X = 1
}

fn use_bound_const() -> u32 {
    BoundConstStruct::C
}

fn match_bound_const(value: u32) -> bool {
    match value {
        BoundConstStruct::C => true,
        _ => false,
    }
}

fn use_bound_const_in_type<T: BoundConst<X = u32>>(_ slot: ConstSlot<{ T::C }>) {}

// Candidate collection lowers associated-type const arguments without
// validating their bodies. Once the impl is selected, `Self::X` in an
// associated-const header must use the checked associated type rather than
// leaking that deferred candidate representation into type equality.
struct TextBoundConstStruct {}

impl BoundConst for TextBoundConstStruct {
    type X = String<4>
    const C: Self::X = "test"
}

fn use_text_bound_const() -> String<4> {
    TextBoundConstStruct::C
}

trait DefaultBoundConst {
    type X
    const C: Self::X = 1
}

struct DefaultBoundConstStruct {}

impl DefaultBoundConst for DefaultBoundConstStruct {
    type X = u32
}

fn use_default_bound_const() -> u32 {
    DefaultBoundConstStruct::C
}

fn use_default_bound_const_in_type<T: DefaultBoundConst<X = u32>>(
    _ slot: ConstSlot<{ T::C }>,
) {
}

trait ForwardingBoundConst {
    type X
    const A: Self::X = 1
    const B: Self::X = Self::A
}

struct ForwardingBoundConstStruct {}

impl ForwardingBoundConst for ForwardingBoundConstStruct {
    type X = u32
}

fn use_forwarding_bound_const() -> u32 {
    ForwardingBoundConstStruct::B
}

trait ConcreteNamedConst {
    const A: u32
    const B: u32 = ConcreteNamedConstStruct::A
}

struct ConcreteNamedConstStruct {}

impl ConcreteNamedConst for ConcreteNamedConstStruct {
    const A: u32 = 1
}

fn use_concrete_named_const() -> u32 {
    ConcreteNamedConstStruct::B
}

trait ConcreteNamedAssocTy {
    type X
    const C: ConcreteNamedAssocTyStruct::X = 1
}

struct ConcreteNamedAssocTyStruct {}

impl ConcreteNamedAssocTy for ConcreteNamedAssocTyStruct {
    type X = u32
}

fn use_concrete_named_assoc_ty() -> u32 {
    ConcreteNamedAssocTyStruct::C
}
