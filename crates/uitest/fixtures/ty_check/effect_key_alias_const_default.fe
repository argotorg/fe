use std::evm::StorageMap

type MyMap<K> = StorageMap<K, u256, 1>

fn needs_map() uses (m: MyMap<u256>) {
    ()
}

msg M {
    #[selector = 0]
    Ping -> (),
}

contract C {
    mut balances: StorageMap<u256, u256>

    recv M {
        Ping -> () uses (balances) {
            needs_map()
        }
    }
}
