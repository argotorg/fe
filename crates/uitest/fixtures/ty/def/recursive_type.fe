pub struct S1 {
    s: S1
}

pub struct S2 {
    s: S3
}

pub struct S3 {
    s: S4
}

pub struct S4 {
    s: S2
}

pub struct S5<T> {
    s: S6,
    t: T,
}

pub struct S6 {
    s: S5<S6>
}

pub struct S7 {
    s: [S7; 1],
}

pub struct S8<T> {
    s: S8<[T; 1]>,
}

// A type that contains a recursive type is not itself part of that type's cycle.
pub struct S9 {
    s: S1,
}
